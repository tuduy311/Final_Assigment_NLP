MODEL_SERVICE_BASE_URL=https://photograph-heritage-attachment-song.trycloudflare.com

# ==========================================
# DRIFT DETECTION THRESHOLDS
# ==========================================
# Cảnh báo nếu model có độ tự tin trung bình (avg_logprob) dưới mức này (âm càng sâu càng tệ)
CONFIDENCE_THRESHOLD=-0.7

# Cảnh báo nếu tỉ lệ nhiễu hoặc không có tiếng người vượt mức này (0.0 -> 1.0)
NO_SPEECH_PROB_THRESHOLD=0.6

# Cảnh báo nếu % đoạn hội thoại quá ngắn (dưới 1s) vượt ngưỡng (0.0 -> 1.0)
# Biểu hiện của việc thuật toán Diarization bị lỗi cắt vụn
SHORT_SEGMENT_RATE_THRESHOLD=0.5

# Cảnh báo Label Drift nếu Word Error Rate (WER) từ người dùng sửa vượt ngưỡng này (20%)
CORRECTION_RATE_THRESHOLD=0.2

# ==========================================
# AGENTIC AI (GEMINI)
# ==========================================
# API Key lấy tại https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
